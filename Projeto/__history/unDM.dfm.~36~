  object qryProdutos: TFDQuery
    Active = True
    Connection = FDConnection
    SQL.Strings = (
      'SELECT'
      'M.cdmrc AS codigo,'
      'M.descrmerc AS descricao,'
      'M.status,'
      'CASE M.status'
      '  WHEN '#39'A'#39' THEN '#39'Ativo'#39
      '  WHEN '#39'I'#39' then '#39'Inativo'#39
      '  ELSE '#39#39
      'END AS status_desc,'
      'M.tipoproduto,'
      'CASE M.tipoproduto'
      '  WHEN '#39'P'#39' THEN '#39'Produto'#39
      '  WHEN '#39'S'#39' then '#39'Servi'#231'o'#39
      '  ELSE '#39#39
      'END AS tipoproduto_desc,'
      'M.cdgrupo AS codigo_grupo,'
      'G.descrgrupo AS grupo_desc,'
      'M.cdsgrup AS codigo_subgrupo,'
      'SG.descrsgrupo AS subgrupo_desc,'
      'M.custo AS preco_custo,'
      'M.prvenda6 AS prvenda_ifood,'
      'M.vendasn AS produto_para_venda,'
      'M.pesoliq AS peso_produto,'
      'M.cdmrc1 AS sku,'
      'M.obs AS descricao_completa_produto,'
      'M.dataua AS data_ultima_atualizacao,'
      'M.destaque as destaque,'
      'CASE M.destaque'
      '  WHEN 0 THEN '#39'N'#227'o'#39
      '  WHEN 1 then '#39'Sim'#39
      '  ELSE '#39#39
      'END AS destaque_desc'
      'FROM mercad M'
      'LEFT JOIN grupo G ON M.cdgrupo = G.cdgrupo'
      'LEFT JOIN subgrupo SG ON M.cdsgrup = SG.cdsgrupo')
    Left = 73
    Top = 264
  end
